pipeline {
    agent any

    environment {
        // Cấu hình thông tin kết nối và định danh
        DOCKER_USERNAME = 'chubedan4605'
        DOMAIN = 'yas.local' // Tên miền base cho hệ thống (được ánh xạ qua file hosts của lập trình viên)
        HELM_TIMEOUT = '5m'
    }

    parameters {
        string(name: 'NAMESPACE', defaultValue: 'dev', description: 'K8s Namespace triển khai (Ví dụ: dev, staging, qa)')
        booleanParam(name: 'DRY_RUN', defaultValue: false, description: 'Chạy mô phỏng (Dry Run) trước. Bỏ check để deploy THỰC TẾ lên K8s.')
        
        // --- Danh sách tham số branch của Backend Services ---
        string(name: 'BRANCH_cart', defaultValue: 'main', description: 'Nhánh git để deploy cho dịch vụ cart (Ví dụ: main, dev_tax_service)')
        string(name: 'BRANCH_customer', defaultValue: 'main', description: 'Nhánh git để deploy cho dịch vụ customer')
        string(name: 'BRANCH_delivery', defaultValue: 'main', description: 'Nhánh git để deploy cho dịch vụ delivery')
        string(name: 'BRANCH_inventory', defaultValue: 'main', description: 'Nhánh git để deploy cho dịch vụ inventory')
        string(name: 'BRANCH_location', defaultValue: 'main', description: 'Nhánh git để deploy cho dịch vụ location')
        string(name: 'BRANCH_media', defaultValue: 'main', description: 'Nhánh git để deploy cho dịch vụ media')
        string(name: 'BRANCH_order', defaultValue: 'main', description: 'Nhánh git để deploy cho dịch vụ order')
        string(name: 'BRANCH_payment', defaultValue: 'main', description: 'Nhánh git để deploy cho dịch vụ payment')
        string(name: 'BRANCH_payment_paypal', defaultValue: 'main', description: 'Nhánh git để deploy cho dịch vụ payment-paypal')
        string(name: 'BRANCH_product', defaultValue: 'main', description: 'Nhánh git để deploy cho dịch vụ product')
        string(name: 'BRANCH_promotion', defaultValue: 'main', description: 'Nhánh git để deploy cho dịch vụ promotion')
        string(name: 'BRANCH_rating', defaultValue: 'main', description: 'Nhánh git để deploy cho dịch vụ rating')
        string(name: 'BRANCH_search', defaultValue: 'main', description: 'Nhánh git để deploy cho dịch vụ search')
        string(name: 'BRANCH_tax', defaultValue: 'main', description: 'Nhánh git để deploy cho dịch vụ tax')
        string(name: 'BRANCH_recommendation', defaultValue: 'main', description: 'Nhánh git để deploy cho dịch vụ recommendation')
        string(name: 'BRANCH_webhook', defaultValue: 'main', description: 'Nhánh git để deploy cho dịch vụ webhook')
        string(name: 'BRANCH_sampledata', defaultValue: 'main', description: 'Nhánh git để deploy cho dịch vụ sampledata')

        // --- Danh sách tham số branch của Frontend & BFF ---
        string(name: 'BRANCH_backoffice_bff', defaultValue: 'main', description: 'Nhánh git để deploy cho backoffice-bff')
        string(name: 'BRANCH_storefront_bff', defaultValue: 'main', description: 'Nhánh git để deploy cho storefront-bff')
        string(name: 'BRANCH_backoffice_ui', defaultValue: 'main', description: 'Nhánh git để deploy cho backoffice-ui')
        string(name: 'BRANCH_storefront_ui', defaultValue: 'main', description: 'Nhánh git để deploy cho storefront-ui')
    }

    stages {
        stage('Khởi tạo & Checkout') {
            steps {
                echo "▶ Đang dọn dẹp thư mục làm việc và tải mã nguồn mới nhất..."
                cleanWs()
                checkout scm
                script {
                    sh '''
                        if ! command -v helm >/dev/null 2>&1; then
                            echo "Helm chưa được cài đặt. Đang tải Helm..."
                            curl -sSL https://get.helm.sh/helm-v3.14.0-linux-amd64.tar.gz -o helm.tar.gz
                            tar -xzf helm.tar.gz
                            mkdir -p bin
                            mv linux-amd64/helm bin/helm
                            chmod +x bin/helm
                        fi
                    '''
                }
            }
        }

        stage('Cấu hình Helm & Kubernetes') {
            steps {
                script {
                    echo "▶ Thiết lập Helm Repositories..."
                    // Cần thiết cho các dependency chung (như stakater)
                    sh "export PATH=\$WORKSPACE/bin:\$PATH; helm repo add stakater https://stakater.github.io/stakater-charts || true"
                    sh "export PATH=\$WORKSPACE/bin:\$PATH; helm repo update"
                }
            }
        }

        stage('Triển khai (Frontend & BFF)') {
            steps {
                script {
                    def bffServices = ['backoffice-bff', 'storefront-bff']
                    def uiServices = ['backoffice-ui', 'storefront-ui']
                    def dryRunFlag = params.DRY_RUN ? "--dry-run" : ""
                    
                    echo "=========================================================="
                    echo "TIẾN HÀNH DEPLOY FRONTEND & BFF (NAMESPACE: ${params.NAMESPACE})"
                    echo "CHẾ ĐỘ MÔ PHỎNG (DRY_RUN): ${params.DRY_RUN}"
                    echo "=========================================================="

                    // Deploy BFF
                    bffServices.each { svc ->
                        def paramName = "BRANCH_${svc.replace('-', '_')}"
                        def branchValue = params."${paramName}"
                        def tagValue = resolveBranchToTag(branchValue, svc)
                        def imageRepository = "${env.DOCKER_USERNAME}/${svc}"
                        def hostName = svc.replace('-bff', '')
                        
                        echo "----------------------------------------------------------"
                        if (branchValue == 'latest' || branchValue == 'main' || !branchValue) {
                            echo "✅ [DEFAULT] ${svc}: Sử dụng nhánh mặc định '${branchValue}' -> Tag 'latest'"
                        } else {
                            echo "🚀 [CUSTOM] ${svc}: Sử dụng nhánh '${branchValue}' -> Tag phân giải được: '${tagValue}'"
                        }

                        sh "export PATH=\$WORKSPACE/bin:\$PATH; helm dependency build k8s/charts/${svc}"
                        sh "export PATH=\$WORKSPACE/bin:\$PATH; helm upgrade --install ${svc} k8s/charts/${svc} " +
                           "--namespace ${params.NAMESPACE} --create-namespace " +
                           "--set backend.image.repository=${imageRepository} " +
                           "--set backend.image.tag=${tagValue} " +
                           "--set backend.ingress.host=${hostName}.${params.NAMESPACE}.${env.DOMAIN} " +
                           "--timeout ${env.HELM_TIMEOUT} " +
                           "${dryRunFlag}"
                    }

                    // Deploy UI
                    uiServices.each { svc ->
                        def paramName = "BRANCH_${svc.replace('-', '_')}"
                        def branchValue = params."${paramName}"
                        def tagValue = resolveBranchToTag(branchValue, svc)
                        def imageRepository = "${env.DOCKER_USERNAME}/${svc.replace('-ui', '')}" // Image thường bỏ hậu tố -ui
                        
                        echo "----------------------------------------------------------"
                        if (branchValue == 'latest' || branchValue == 'main' || !branchValue) {
                            echo "✅ [DEFAULT] ${svc}: Sử dụng nhánh mặc định '${branchValue}' -> Tag 'latest'"
                        } else {
                            echo "🚀 [CUSTOM] ${svc}: Sử dụng nhánh '${branchValue}' -> Tag phân giải được: '${tagValue}'"
                        }

                        sh "export PATH=\$WORKSPACE/bin:\$PATH; helm dependency build k8s/charts/${svc}"
                        sh "export PATH=\$WORKSPACE/bin:\$PATH; helm upgrade --install ${svc} k8s/charts/${svc} " +
                           "--namespace ${params.NAMESPACE} --create-namespace " +
                           "--set ui.image.repository=${imageRepository} " +
                           "--set ui.image.tag=${tagValue} " +
                           "--timeout ${env.HELM_TIMEOUT} " +
                           "${dryRunFlag}"
                    }
                    
                    if (!params.DRY_RUN) {
                        echo "⏳ Tạm dừng 20s để Frontend ổn định..."
                        sleep 20
                    }
                }
            }
        }

        stage('Triển khai Swagger UI') {
            steps {
                script {
                    echo "▶ Deploy Swagger-UI..."
                    def dryRunFlag = params.DRY_RUN ? "--dry-run" : ""
                    sh "export PATH=\$WORKSPACE/bin:\$PATH; helm upgrade --install swagger-ui k8s/charts/swagger-ui " +
                       "--namespace ${params.NAMESPACE} --create-namespace " +
                       "--set ingress.host=api.${params.NAMESPACE}.${env.DOMAIN} " +
                       "--timeout ${env.HELM_TIMEOUT} " +
                       "${dryRunFlag}"
                       
                    if (!params.DRY_RUN) {
                        echo "⏳ Tạm dừng 10s sau khi cài Swagger..."
                        sleep 10
                    }
                }
            }
        }

        stage('Triển khai Backend Services') {
            steps {
                script {
                    def backendServices = [
                        'cart', 'customer', 'inventory', 'location', 'media', 'order', 'payment', 
                        'payment-paypal', 'product', 'promotion', 'rating', 'search', 'tax', 'recommendation', 
                        'webhook', 'sampledata'
                    ]
                    def dryRunFlag = params.DRY_RUN ? "--dry-run" : ""
                    
                    echo "=========================================================="
                    echo "TIẾN HÀNH DEPLOY BACKEND MICROSERVICES"
                    echo "=========================================================="

                    backendServices.each { svc ->
                        def paramName = "BRANCH_${svc.replace('-', '_')}"
                        def branchValue = params."${paramName}"
                        def tagValue = resolveBranchToTag(branchValue, svc)
                        def imageRepository = "${env.DOCKER_USERNAME}/${svc}"
                        
                        echo "----------------------------------------------------------"
                        if (branchValue == 'latest' || branchValue == 'main' || !branchValue) {
                            echo "✅ [DEFAULT] ${svc}: Sử dụng nhánh mặc định '${branchValue}' -> Tag 'latest'"
                        } else {
                            echo "🚀 [CUSTOM] ${svc}: Sử dụng nhánh '${branchValue}' -> Tag phân giải được: '${tagValue}'"
                        }
                        
                        sh "export PATH=\$WORKSPACE/bin:\$PATH; helm dependency build k8s/charts/${svc}"
                        def helmCmd = "export PATH=\$WORKSPACE/bin:\$PATH; helm upgrade --install ${svc} k8s/charts/${svc} " +
                                      "--namespace ${params.NAMESPACE} --create-namespace " +
                                      "--set backend.image.repository=${imageRepository} " +
                                      "--set backend.image.tag=${tagValue} " +
                                      "--set backend.ingress.host=api.${params.NAMESPACE}.${env.DOMAIN} " +
                                      "--timeout ${env.HELM_TIMEOUT} " +
                                      "${dryRunFlag}"
                        sh "${helmCmd}"
                    }
                    
                    echo "=========================================================="
                    echo "🎉 HOÀN THÀNH QUÁ TRÌNH TRIỂN KHAI VÀO: ${params.NAMESPACE}"
                    echo "=========================================================="
                }
            }
        }
    }
    
    post {
        always {
            script {
                echo "▶ Hoàn tất Pipeline. Dọn dẹp Workspace."
                cleanWs()
            }
        }
        success {
            echo "✅ DEVELOPER BUILD COMPLETED SUCCESSFULLY."
        }
        failure {
            echo "❌ DEVELOPER BUILD FAILED. Vui lòng kiểm tra log ở trên để xem chi tiết lỗi Kubernetes/Helm."
        }
    }
}

def resolveBranchToTag(String branchName, String serviceName) {
    if (!branchName || branchName == 'main' || branchName == 'latest') {
        return 'latest'
    }
    try {
        def remoteRef = sh(script: "git ls-remote origin refs/heads/${branchName}", returnStdout: true).trim()
        if (remoteRef) {
            def commitHash = remoteRef.split()[0]
            if (commitHash && commitHash.length() >= 7) {
                def shortHash = commitHash.substring(0, 7)
                echo "Resolved branch '${branchName}' for service '${serviceName}' to commit tag: ${shortHash}"
                return shortHash
            }
        }
        echo "⚠️ Branch '${branchName}' for service '${serviceName}' not found or invalid remote ref. Falling back to 'latest'."
        return 'latest'
    } catch (Exception e) {
        echo "⚠️ Error resolving branch '${branchName}' for service '${serviceName}': ${e.message}. Falling back to 'latest'."
        return 'latest'
    }
}
